{
  "name": "mern_project",
  "version": "1.0.0",
  "description": "a backend project learning series",
  "keywords": [
    "node",
    "express",
    "youtube"
  ],
  "homepage": "https://github.com/Stack-Sage/MERN-Project-#readme",
  "bugs": {
    "url": "https://github.com/Stack-Sage/MERN-Project-/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stack-Sage/MERN-Project-.git"
  },
  "license": "ISC",
  "author": "Adarsh",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "dev": "nodemon --legacy-watch src/index.js",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:unit": "NODE_ENV=test vitest run test/unit",
    "test:integration": "NODE_ENV=test vitest run test/integration"
  },
  "lint-staged": {
    "*.{js,json,md}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.17.0",
    "mongoose-aggregate-paginate-v2": "^1.1.4",
    "multer": "^2.0.2",
    "rate-limit-redis": "^5.0.0",
    "redis": "^6.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.15",
    "winston": "^3.19.0"
  }
}
